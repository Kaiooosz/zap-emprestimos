generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Acesso ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  OPERADOR
  COBRADOR
}

model User {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(OPERADOR)
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  emprestimos Emprestimo[]

  @@map("users")
}

// ─── Clientes ─────────────────────────────────────────────────────────────────

enum TipoCliente {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

model Cliente {
  id               String      @id @default(cuid())
  tipo             TipoCliente @default(PESSOA_FISICA)
  nome             String
  cpf              String?
  phone            String
  email            String?
  endereco         String?
  cidade           String?
  estado           String?
  profissao        String?
  rendaMensal      Decimal?    @db.Decimal(12, 2)
  score            Int         @default(500)
  temContrato      Boolean     @default(false)
  garantia         Boolean     @default(false)
  tipoGarantia     String?
  valorGarantia    Decimal?    @db.Decimal(12, 2)
  descGarantia     String?
  referencia       String?
  observacoes      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  emprestimos    Emprestimo[]
  scoreHistorico ScoreHistorico[]

  @@map("clientes")
}

// ─── Empréstimos ──────────────────────────────────────────────────────────────

enum TipoProduto {
  EMPRESTIMO
  DIARIO
  DESCONTO_CHEQUE
  RENOVACAO
  VENDA
  ALUGUEL
  ASSINATURA
}

enum TipoPeriodo {
  DIARIO
  SEMANAL
  QUINZENAL
  MENSAL
}

enum ModalidadeJuros {
  SIMPLES
  POR_PARCELA
}

enum StatusEmprestimo {
  ATIVO
  QUITADO
  INADIMPLENTE
  CANCELADO
}

model Emprestimo {
  id               String           @id @default(cuid())
  clienteId        String
  operadorId       String
  tipoProduto      TipoProduto      @default(EMPRESTIMO)
  tipo             TipoPeriodo      @default(MENSAL)
  modalidadeJuros  ModalidadeJuros  @default(SIMPLES)
  status           StatusEmprestimo @default(ATIVO)
  valorPrincipal   Decimal          @db.Decimal(12, 2)
  taxaJuros        Decimal          @db.Decimal(6, 2)
  totalJuros       Decimal          @db.Decimal(12, 2)
  valorTotal       Decimal          @db.Decimal(12, 2)
  numParcelas      Int
  dataInicio       DateTime
  dataVencimento   DateTime
  temGarantia      Boolean          @default(false)
  tipoGarantia     String?
  valorGarantia    Decimal?         @db.Decimal(12, 2)
  temContrato      Boolean          @default(false)
  observacoes      String?
  regraAtraso      String           @default("PARCELA")
  taxaAtraso       Decimal          @default(1.0) @db.Decimal(5, 2)
  tipoTaxaAtraso   String           @default("PERCENTUAL")
  // Campos específicos por tipo
  valorNominalCheque Decimal?       @db.Decimal(12, 2)
  dataCheque         DateTime?
  custo              Decimal?       @db.Decimal(12, 2)
  descricaoProduto   String?
  valorMensal        Decimal?       @db.Decimal(12, 2)
  diaVencimento      Int?
  semDataFim         Boolean        @default(false)
  plano              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  cliente  Cliente   @relation(fields: [clienteId], references: [id])
  operador User      @relation(fields: [operadorId], references: [id])
  parcelas Parcela[]

  @@map("emprestimos")
}

// ─── Parcelas ─────────────────────────────────────────────────────────────────

enum StatusParcela {
  PENDENTE
  PAGO
  ATRASADO
  PARCIAL
}

enum ModoPagamento {
  COMPLETO
  SOMENTE_JUROS
  QUITACAO_TOTAL
  ANTECIPADO
  ABATIMENTO
}

model Parcela {
  id               String         @id @default(cuid())
  emprestimoId     String
  numero           Int
  valorDevido      Decimal        @db.Decimal(12, 2)
  valorPrincipal   Decimal        @db.Decimal(12, 2)
  valorJuros       Decimal        @db.Decimal(12, 2)
  valorPago        Decimal?       @db.Decimal(12, 2)
  dataVencimento   DateTime
  dataPagamento    DateTime?
  status           StatusParcela  @default(PENDENTE)
  modoPagamento    ModoPagamento?
  desconto         Decimal?       @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())

  emprestimo Emprestimo @relation(fields: [emprestimoId], references: [id], onDelete: Cascade)

  @@map("parcelas")
}

// ─── Score Histórico ──────────────────────────────────────────────────────────

model ScoreHistorico {
  id          String   @id @default(cuid())
  clienteId   String
  tipo        String
  descricao   String
  pontos      Int
  scoreAntes  Int
  scoreDepois Int
  data        DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("score_historico")
}

// ─── Financeiro Interno ───────────────────────────────────────────────────────

enum CategoriaContaPagar {
  ALUGUEL
  SALARIO
  IMPOSTO
  SERVICO
  MARKETING
  TECNOLOGIA
  OUTROS
}

enum StatusConta {
  PENDENTE
  PAGO
  VENCIDO
}

model ContaPagar {
  id             String              @id @default(cuid())
  descricao      String
  categoria      CategoriaContaPagar @default(OUTROS)
  valor          Decimal             @db.Decimal(12, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         StatusConta         @default(PENDENTE)
  recorrente     Boolean             @default(false)
  createdAt      DateTime            @default(now())

  @@map("contas_pagar")
}

// ─── Configurações ────────────────────────────────────────────────────────────

model Config {
  id    String @id @default("singleton")
  data  Json
  updatedAt DateTime @updatedAt

  @@map("config")
}

// ─── Templates WhatsApp ───────────────────────────────────────────────────────

model Template {
  id       String @id @default(cuid())
  nome     String
  conteudo String @db.Text
  ativo    Boolean @default(true)
  createdAt DateTime @default(now())

  @@map("templates")
}

// ─── Auditoria e Filas ────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userNome  String?
  acao      String
  detalhes  String   @db.Text
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model MsgQueue {
  id         String   @id @default(cuid())
  clienteId  String
  mensagem   String   @db.Text
  telefone   String
  status     String   @default("PENDENTE") // PENDENTE, ENVIADO, FALHOU
  tentativas Int      @default(0)
  erro       String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("msg_queue")
}
